<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sercop_document_tree" model="ir.ui.view">
        <field name="name">sercop.document.tree</field>
        <field name="model">sercop.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="document_type"/>
                <field name="filename"/>
                <field name="proceso_id"/>
                <field name="create_date"/>
                <button name="action_download" type="object" string="Descargar" class="btn-secondary"/>
            </tree>
        </field>
    </record>

    <record id="view_sercop_document_form" model="ir.ui.view">
        <field name="name">sercop.document.form</field>
        <field name="model">sercop.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="document_type"/>
                            <field name="proceso_id"/>
                        </group>
                        <group>
                            <field name="file" filename="filename" required="1"/>
                            <field name="filename" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
