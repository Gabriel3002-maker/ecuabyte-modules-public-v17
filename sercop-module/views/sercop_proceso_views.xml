<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sercop_proceso_tree" model="ir.ui.view">
        <field name="name">sercop.proceso.tree</field>
        <field name="model">sercop.proceso</field>
        <field name="arch" type="xml">
            <tree>
                <field name="codigo_contratacion"/>
                <field name="objeto_contratacion"/>
                <field name="entidad_contratante"/>
                <field name="provincia"/>
                <field name="estado"/>
                <field name="fecha_publicacion"/>
                <field name="fecha_limite_propuesta"/>
                <field name="es_tecnologia" widget="badge" decoration-success="es_tecnologia"/>
                <field name="lead_creado" widget="badge" decoration-success="lead_creado"/>
            </tree>
        </field>
    </record>

    <record id="view_sercop_proceso_form" model="ir.ui.view">
        <field name="name">sercop.proceso.form</field>
        <field name="model">sercop.proceso</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_lead" type="object"
                            string="Crear Oportunidad CRM"
                            class="btn-primary"
                            invisible="lead_creado"/>
                    <button name="action_open_lead" type="object"
                            string="Ver Oportunidad CRM"
                            class="btn-info"
                            invisible="not lead_creado"/>
                    <button name="action_open_detalle" type="object"
                            string="Abrir en SERCOP"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="codigo_contratacion"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tipo_necesidad"/>
                            <field name="estado"/>
                            <field name="fecha_publicacion"/>
                            <field name="fecha_limite_propuesta"/>
                            <field name="es_tecnologia"/>
                            <field name="lead_creado"/>
                        </group>
                        <group>
                            <field name="entidad_contratante"/>
                            <field name="provincia"/>
                            <field name="canton"/>
                            <field name="direccion_entrega"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Objeto de Contratación">
                            <field name="objeto_contratacion" nolabel="1"/>
                        </page>
                        <page string="Contacto">
                            <group>
                                <group>
                                    <field name="funcionario"/>
                                    <field name="email_contacto"/>
                                    <field name="telefono_contacto"/>
                                </group>
                                <group>
                                    <field name="contacto" nolabel="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Valores">
                            <group>
                                <field name="valor_unitario"/>
                                <field name="cantidad"/>
                                <field name="tcom_necesidad_contratacion_id"/>
                                <field name="seq_tipo_necesidad"/>
                                <field name="seq_estado"/>
                                <field name="url_entidad"/>
                            </group>
                        </page>
                        <page string="Oportunidad CRM" invisible="not lead_id">
                            <field name="lead_id" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sercop_proceso_search" model="ir.ui.view">
        <field name="name">sercop.proceso.search</field>
        <field name="model">sercop.proceso</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_contratacion"/>
                <field name="objeto_contratacion"/>
                <field name="entidad_contratante"/>
                <filter name="tecnologia" string="Solo Tecnología"
                        domain="[('es_tecnologia', '=', True)]"/>
                <filter name="sin_lead" string="Sin Oportunidad"
                        domain="[('lead_creado', '=', False)]"/>
                <separator/>
                <filter name="en_curso" string="En Curso"
                        domain="[('estado', '=', 'En Curso')]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_estado" string="Estado"
                            domain="[]" context="{'group_by': 'estado'}"/>
                    <filter name="group_provincia" string="Provincia"
                            domain="[]" context="{'group_by': 'provincia'}"/>
                    <filter name="group_tecnologia" string="Es Tecnología"
                            domain="[]" context="{'group_by': 'es_tecnologia'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sercop_proceso_kanban" model="ir.ui.view">
        <field name="name">sercop.proceso.kanban</field>
        <field name="model">sercop.proceso</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="codigo_contratacion"/>
                <field name="objeto_contratacion"/>
                <field name="entidad_contratante"/>
                <field name="estado"/>
                <field name="es_tecnologia"/>
                <field name="lead_creado"/>
                <field name="fecha_limite_propuesta"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="codigo_contratacion"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="oe_kanban_details">
                                <div>
                                    <field name="objeto_contratacion"/>
                                </div>
                                <div>
                                    <field name="entidad_contratante"/>
                                </div>
                                <div class="text-muted o_kanban_record_subtitle">
                                    <field name="fecha_limite_propuesta"/>
                                </div>
                                <div class="mt-4">
                                    <field name="estado" class="oe_kanban_text_badge"/>
                                    <field name="es_tecnologia" widget="badge" decoration-success="es_tecnologia"/>
                                    <field name="lead_creado" widget="badge" decoration-success="lead_creado"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
