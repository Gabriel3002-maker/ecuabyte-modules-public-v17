<odoo>
    <data noupdate="1">
        <record id="ir_cron_sercop_import" model="ir.cron">
            <field name="name">SERCOP - Importar procesos</field>
            <field name="model_id" ref="model_sercop_proceso"/>
            <field name="state">code</field>
            <field name="code">model.cron_importar_procesos()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=6, minute=0, second=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">5</field>
        </record>
    </data>
</odoo>
